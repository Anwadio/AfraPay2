{
  "name": "@afrapay/backend",
  "version": "1.0.0",
  "description": "AfraPay Fintech Backend API - Production-ready Node.js + Express server",
  "main": "src/server.js",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "start:prod": "NODE_ENV=production node src/server.js",
    "test": "jest --detectOpenHandles",
    "test:watch": "jest --watch --detectOpenHandles",
    "test:coverage": "jest --coverage --detectOpenHandles",
    "test:integration": "jest --testPathPattern=tests/integration --runInBand",
    "lint": "eslint src --ext .js",
    "lint:fix": "eslint src --ext .js --fix",
    "format": "prettier --write \"src/**/*.js\" \"tests/**/*.js\"",
    "format:check": "prettier --check \"src/**/*.js\" \"tests/**/*.js\"",
    "security:audit": "npm audit && node src/scripts/securityCheck.js",
    "logs:clear": "rm -rf logs/*",
    "db:migrate": "node src/database/migrations/migrate.js",
    "db:seed": "node src/database/seeders/seed.js",
    "backup:db": "node src/database/backup/backupScheduler.js",
    "docs:generate": "swagger-jsdoc -d swaggerDef.js src/routes/v1/*.js -o docs/swagger.json",
    "health:check": "node src/scripts/healthCheck.js",
    "monitoring:start": "pm2 start ecosystem.config.js",
    "monitoring:stop": "pm2 stop ecosystem.config.js"
  },
  "dependencies": {
    "@googlemaps/google-maps-services-js": "^3.3.42",
    "appwrite": "^13.0.2",
    "axios": "^1.6.2",
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "config": "^3.3.9",
    "connect-redis": "^7.1.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "crypto": "^1.0.1",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-async-errors": "^3.1.1",
    "express-rate-limit": "^7.1.5",
    "express-request-id": "^3.0.0",
    "express-session": "^1.17.3",
    "express-validator": "^7.0.1",
    "google-auth-library": "^10.6.1",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.2",
    "joi": "^17.11.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "node-appwrite": "^12.0.1",
    "node-cron": "^3.0.3",
    "nodemailer": "^6.9.7",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "paystack": "^2.0.1",
    "qrcode": "^1.5.3",
    "redis": "^4.6.10",
    "resend": "^6.9.3",
    "sharp": "^0.33.1",
    "socket.io": "^4.8.3",
    "speakeasy": "^2.0.0",
    "stripe": "^14.9.0",
    "twilio": "^4.19.3",
    "uuid": "^9.0.1",
    "winston": "^3.11.0",
    "winston-daily-rotate-file": "^4.7.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "eslint": "^8.55.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-plugin-import": "^2.29.0",
    "eslint-plugin-jest": "^27.6.0",
    "eslint-plugin-security": "^1.7.1",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "pm2": "^5.3.0",
    "prettier": "^3.1.0",
    "supertest": "^6.3.3",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "keywords": [
    "fintech",
    "payments",
    "api",
    "express",
    "nodejs",
    "financial-services",
    "security",
    "scalable"
  ],
  "author": "AfraPay Development Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/afrapay/backend.git"
  },
  "bugs": {
    "url": "https://github.com/afrapay/backend/issues"
  },
  "homepage": "https://github.com/afrapay/backend#readme"
}
