# Backend Environment Variables

# Application
NODE_ENV=development
PORT=5000
HOST=0.0.0.0

# Appwrite Configuration
APPWRITE_API_KEY=standard_6f81ffdb918cfdcaaff83bf87c9d32cd5cdc027345c918af24f46702ea004c91e85e290f122714d7cf82158f8c1b0f9c495e1c6b2645aa60b815b31dc0e421dc96ab0b13d2d15173f3d4fe3f1b0f975757d456063097e47f5f589de45fe24a126ad64819b4545e323c4010e165b5f333c2c72e62658f3e83d30fabc5ea7665ac
APPWRITE_DATABASE_ID=69720e41002429abc875
APPWRITE_ENDPOINT=https://fra.cloud.appwrite.io/v1
APPWRITE_PROJECT_ID=6972090b003512312836

# Admin User Setup (for setup-admin-user.js script)
ADMIN_EMAIL=admin@afrapayafrica.com
ADMIN_PASSWORD=AdminPass123!
ADMIN_NAME=AfraPay Administrator

# Collection IDs
USERS_COLLECTION_ID=users
TRANSACTIONS_COLLECTION_ID=transactions
WALLETS_COLLECTION_ID=wallets
DOCUMENTS_COLLECTION_ID=kyc_documents
AUDIT_LOGS_COLLECTION_ID=audit_logs
SESSIONS_COLLECTION_ID=sessions
WEBHOOK_LOGS_COLLECTION_ID=webhook_logs

# Storage Bucket IDs
AVATARS_BUCKET_ID=avatars
DOCUMENTS_BUCKET_ID=documents

# Redis Configuration (Optional - for caching)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_ENABLED=false

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_minimum_32_characters_long
JWT_REFRESH_SECRET=your_refresh_secret_key_minimum_32_characters
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Encryption
ENCRYPTION_KEY=your_32_character_encryption_key_123

# Security
COOKIE_SECRET=your_cookie_secret_minimum_32_chars_long
APP_URL=https://www.afrapayafrica.com
CORS_ORIGIN=http://localhost:3000,https://www.afrapayafrica.com,https://afrapayafrica.com
COOKIE_DOMAIN=
COOKIE_SAME_SITE=none

# Rate Limiting
RATE_LIMIT_WINDOW=900000
RATE_LIMIT_MAX_REQUESTS=100
ENABLE_RATE_LIMITING=true

# File Upload
MAX_FILE_SIZE=5242880
UPLOAD_PATH=./uploads

# External Services (Optional)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

SENDGRID_API_KEY=
FROM_EMAIL=noreply@afrapay.com

# Payment Gateways (Optional)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=

FLUTTERWAVE_SECRET_KEY=
FLUTTERWAVE_ENCRYPTION_KEY=
FLUTTERWAVE_WEBHOOK_SECRET=
FLUTTERWAVE_REDIRECT_URL=https://yourapp.com/payments/complete

# M-Pesa (Safaricom Daraja API)
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=
MPESA_PASSKEY=
MPESA_CALLBACK_URL=https://yourapp.com/api/v1/webhooks/mpesa
MPESA_ENV=sandbox

# MTN Mobile Money (Collections API)
MTN_MOMO_SUBSCRIPTION_KEY=
MTN_MOMO_API_USER_ID=
MTN_MOMO_API_KEY=
MTN_MOMO_CALLBACK_URL=https://yourapp.com/api/v1/webhooks/mtn
MTN_MOMO_TARGET_ENV=sandbox
MTN_MOMO_CURRENCY=EUR

# Monitoring
LOG_LEVEL=info
ENABLE_REQUEST_LOGGING=true
SENTRY_DSN=

# Features
ENABLE_SWAGGER=true
ENABLE_WEBSOCKETS=true